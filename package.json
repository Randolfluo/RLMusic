{
  "name": "localmusicplayer",
  "private": true,
  "version": "1.0.0",
  "author": "Randolfluo",
  "home": "https://randolfluo.top",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --host",
    "build": "vue-tsc -b && vite build && electron-builder",
    "build:go": "cd server && go mod tidy && go build -o ../resources/server.exe cmd/main.go",
    "build:server": "npm run build:go && cross-env VITE_APP_MODE=server vue-tsc -b && cross-env VITE_APP_MODE=server vite build && electron-builder --config electron-builder.server.json",
    "build:client": "cross-env VITE_APP_MODE=client vue-tsc -b && cross-env VITE_APP_MODE=client vite build && electron-builder --config electron-builder.client.json",
    "build:web": "vue-tsc -b && vite build",
    "build:android": "vue-tsc -b && vite build && pnpm exec cap sync android && pnpm exec cap open android",
    "build:all": "npm run build:server && npm run build:client && pnpm build:web && pnpm exec cap sync android && pnpm exec cap open android",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "^8.0.1",
    "@capacitor/android": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@icon-park/vue-next": "^1.4.2",
    "@ivanv/vue-collapse-transition": "^1.0.2",
    "@vicons/carbon": "^0.13.0",
    "artplayer": "^5.3.0",
    "axios": "^1.13.2",
    "crypto-js": "^4.2.0",
    "echarts": "^6.0.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "plyr": "^3.8.4",
    "qrcode.vue": "^3.6.0",
    "sass": "^1.97.2",
    "screenfull": "^6.0.2",
    "vue": "^3.5.24",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^24.10.1",
    "@vicons/material": "^0.13.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.24",
    "cross-env": "^10.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "naive-ui": "^2.43.2",
    "postcss": "^8.5.6",
    "tailwindcss": "3.4.17",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.2.4",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-pwa": "^1.2.0",
    "vue-tsc": "^3.1.4"
  },
  "build": {
    "appId": "com.randolfluo.localmusicplayer",
    "productName": "LocalMusicPlayer",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "win": {
      "icon": "public/images/logo/favicon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Windows-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": "dmg",
      "artifactName": "${productName}-Mac-${version}-Installer.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "${productName}-Linux-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Windows-Portable-${version}.${ext}"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "vue-tsc"
    ]
  }
}
