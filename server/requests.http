### 全局变量
@baseUrl = http://localhost:3000/api
@contentType = application/json
@username = testuser003
@password = password123
@email = test001@example.com

### 1. 用户注册
# 如果遇到 "数据库操作异常 (9004)" 或 "User exist"，说明用户已存在，请直接运行第 2 步 "用户登录"
POST {{baseUrl}}/auth/register
Content-Type: {{contentType}}

{
    "username": "{{username}}",
    "password": "{{password}}",
    "email": "{{email}}"
}
# {
#   "code": 1000,
#   "message": "success",
#   "data": {}
# }

### 2. 用户登录
# @name login
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
    "username": "{{username}}",
    "password": "{{password}}"
}
# Response Example:
# {
#   "code": 1000,
#   "message": "登录成功",
#   "data": {
#     "token": "eyJhbGciOiJIUzI1NiIs...",
#     "user": {
#       "id": 1,
#       "username": "testuser001",
#       "email": "test001@example.com",
#       "avatar": "",
#       "role": "user"
#     }
#   }
# }


### 4. 注销用户 (需要登录后获取Token)
DELETE {{baseUrl}}/user
Authorization: Bearer {{login.response.body.data.token}}
# {
#   "code": 1000,
#   "message": "success",
#   "data": null
# }

### 5. 初始化基础文件夹 (不需要认证)
POST {{baseUrl}}/file/initFolder
Content-Type: {{contentType}}
# {
#   "code": 1000,
#   "message": "success",
#   "data": "文件夹已存在"
# }

### 6. 初始化用户目录 (内部调用，已移除接口)
# (用户注册时自动调用，不再提供独立接口)

### 7. 获取系统设置 (需要登录后获取Token)
GET {{baseUrl}}/system/settings
Authorization: Bearer {{login.response.body.data.token}}
# {
#   "code": 1000,
#   "message": "success",
#   "data": {
#     "TotalSongs": 0,
#     "TotalAlbums": 0,
#     "TotalArtists": 0,
#     "IsBaseFolderCreated": true
#   }
# }

### 7-2. 获取时长统计 (需要登录)
GET {{baseUrl}}/system/duration
Authorization: Bearer {{login.response.body.data.token}}
# {
#   "code": 1000,
#   "message": "success",
#   "data": {
#     "user_total_duration": 0,
#     "system_total_duration": 0
#   }
# }

### 8. 扫描用户音乐 (需要登录)
# !!! 必须先运行上面的 "2. 用户登录" 请求，获取到 Token 后才能运行此请求 !!!
POST {{baseUrl}}/song/scan
Authorization: Bearer {{login.response.body.data.token}}
# {
#   "code": 1000,
#   "message": "success",
#   "data": {
#     "added": 0,
#     "message": "扫描完成",
#     "updated": 183
#   }
# }

### 11. 播放歌曲 (无需登录，替换 ID)
GET {{baseUrl}}/song/stream/1
# Response: (Binary Audio Data)




### 11-2. 获取歌单详情 (无需登录，替换 ID)
GET {{baseUrl}}/song/playlist/1

# {
#   "code": 1000,
#   "message": "success",
#   "data": [
#     {
#       "id": 1,
#       "title": "光辉岁月",
#       "artist_name": "Beyond",
#       "album_title": "黄家驹原作精选集",
#       "duration": 297.5466666666667
#     },
#     ]
# }

### 12. 管理员登录
# @name adminLogin
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
    "username": "admin",
    "password": "123456"
}

### 13. 更新系统配置 (仅管理员)
POST {{baseUrl}}/system/config
Content-Type: {{contentType}}
Authorization: Bearer {{adminLogin.response.body.data.token}}

{
    "filepath": 'C:\Users\lrj32\Desktop\music player\localmusicplayerFoleder'
}
# Response Example:
# {
#   "code": 1000,
#   "message": "配置更新成功",
#   "data": null
# }

