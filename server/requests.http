#         "artist_id": 0,
#         "album_id": 0,
#         "cover_url": ""
#       }
#     ]
#   }
# }

### 11-3. 点赞/取消点赞歌曲 (需要登录)
POST {{baseUrl}}/song/like/1
Authorization: Bearer {{login.response.body.data.token}}
# {
#   "code": 1000,
#   "message": "success",
#   "data": {
#     "liked": true,
#     "message": "已添加到喜欢"
#   }
# }

### 12. 管理员登录
# @name adminLogin
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
    "username": "admin",
    "password": "123456"
}

### 13. 更新系统配置 (仅管理员)
POST {{baseUrl}}/system/config
Content-Type: {{contentType}}
Authorization: Bearer {{adminLogin.response.body.data.token}}

{
    "filepath": 'C:\Users\lrj32\Desktop\music player\localmusicplayerFoleder'
}
# Response Example:
# {
#   "code": 1000,
#   "message": "配置更新成功",
#   "data": null
# }

### 14. 获取所有公开歌单 (无需登录)
GET {{baseUrl}}/song/playlists/public
# 返回 is_public=true 的歌单

### 14-2. 获取我的公开歌单 (需要登录)
GET {{baseUrl}}/song/playlists/user/public
Authorization: Bearer {{login.response.body.data.token}}
# 返回 owner_id 为当前用户，且 is_public=true 的歌单

### 14-3. 获取我的私有歌单 (需要登录)
GET {{baseUrl}}/song/playlists/user/private
Authorization: Bearer {{login.response.body.data.token}}
# 返回 owner_id 为当前用户，且 is_public=false 的歌单

### 15. 更新歌单信息(包括权限) (需要登录)
PUT {{baseUrl}}/song/playlist/1
Authorization: Bearer {{login.response.body.data.token}}
Content-Type: {{contentType}}

{
    "title": "已修改的歌单名称",
    "description": "这是新的描述",
    "is_public": false
}
# {
#   "code": 1000,
#   "message": "success",
#   "data": "更新成功"
# }

### 16. 退出登录 (需要登录)
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{login.response.body.data.token}}
# {
#   "code": 1000,
#   "message": "success",
#   "data": null
# }

### 16. 上传用户头像 (需要登录)
POST {{baseUrl}}/user/avatar
Authorization: Bearer {{login.response.body.data.token}}
Content-Type: multipart/form-data; boundary=MyBoundary

# {
#   "code": 1000,
#   "message": "success",
#   "data": "/api/file/avatar/user_3_1770028087.png"
# }

### 17. 记录播放历史
POST {{baseUrl}}/song/history
Authorization: Bearer {{login.response.body.data.token}}
Content-Type: application/json

{
    "song_id": 1
}

### 18. 获取播放历史
GET {{baseUrl}}/song/history?page=1&limit=20
Authorization: Bearer {{login.response.body.data.token}}

### 19. 清空播放历史
DELETE {{baseUrl}}/song/history
Authorization: Bearer {{login.response.body.data.token}}

### 20. 搜索建议
GET {{baseUrl}}/search/suggest?keywords=Test
Authorization: Bearer {{login.response.body.data.token}}

### 21. 搜索详情 (歌曲)
GET {{baseUrl}}/search/detail?keywords=Test&type=1&offset=1&limit=10
Authorization: Bearer {{login.response.body.data.token}}

