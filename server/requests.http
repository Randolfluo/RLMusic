### 全局变量
@baseUrl = http://localhost:3000/api
@contentType = application/json
@username = testuser001
@password = password123
@email = test001@example.com

### 1. 用户注册
# 如果遇到 "数据库操作异常 (9004)" 或 "User exist"，说明用户已存在，请直接运行第 2 步 "用户登录"
POST {{baseUrl}}/auth/register
Content-Type: {{contentType}}

{
    "username": "{{username}}",
    "password": "{{password}}",
    "email": "{{email}}"
}
# {
#   "code": 1000,
#   "message": "success",
#   "data": {}
# }

### 2. 用户登录
# @name login
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
    "username": "{{username}}",
    "password": "{{password}}"
}
# {
#   "code": 1000,
#   "message": "登录成功",
#   "data": {
#     "token": "eyJhbGciOiJIUzI1NiIs...",
#     "user": {
#       "id": 1,
#       "username": "testuser001",
#       "email": "test001@example.com",
#       "avatar": "",
#       "role": "user"
#     }
#   }
# }


### 3. 获取用户信息 (需要登录)
# @name getUserInfo
GET {{baseUrl}}/user/info
Authorization: Bearer {{login.response.body.data.token}}
# {
#   "code": 1000,
#   "message": "success",
#   "data": {
#     "id": 2,
#     "username": "testuser001",
#     "email": "test1@example.com",
#     "avatar": "",
#     "last_login": "2026-02-06T16:10:40.3265431+08:00",
#     "total_songs": 1166,
#     "total_albums": 680,
#     "total_artists": 536,
#     "total_duration": 0,
#     "favorite_song": ""
#   }
# }

### 4. 注销用户 (需要登录后获取Token)
DELETE {{baseUrl}}/user
Authorization: Bearer {{login.response.body.data.token}}
# {
#   "code": 1000,
#   "message": "success",
#   "data": null
# }

### 5. 初始化基础文件夹 (不需要认证)
POST {{baseUrl}}/file/initFolder
Content-Type: {{contentType}}
# {
#   "code": 1000,
#   "message": "success",
#   "data": "文件夹已存在"
# }

### 6. 初始化用户目录 (内部调用，已移除接口)
# (用户注册时自动调用，不再提供独立接口)

### 7. 获取系统统计信息 (无需登录) (系统设置+时长统计)
GET {{baseUrl}}/system/stats
# {
#   "code": 1000,
#   "message": "success",
#   "data": {
#     "song_count": 1166,
#     "album_count": 680,
#     "artist_count": 536,
#     "music_duration": 272187,
#     "playlist_count": 15,
#     "user_count": 6,
#     "system_uptime": 34,
#     "user_listening_duration": 0,
#     "user_scanned_duration": 0,
#     "cpu_usage": 12.5,
#     "mem_usage": 45.2,
#     "api_call_count": 1024
#   }
# }
### 8. 扫描用户音乐 (需要登录)
# !!! 必须先运行上面的 "2. 用户登录" 请求，获取到 Token 后才能运行此请求 !!!
POST {{baseUrl}}/song/scan
Authorization: Bearer {{login.response.body.data.token}}
# {
#   "code": 1000,
#   "message": "success",
#   "data": {
#     "added": 0,
#     "message": "扫描完成",
#     "updated": 183
#   }
# }

### 11. 播放歌曲 (无需登录，替换 ID)
GET {{baseUrl}}/song/stream/1
# Response: (Binary Audio Data)

### 11-1. 获取歌曲详情
GET {{baseUrl}}/song/detail/1
# {
#   "code": 1000,
#   "message": "success",
