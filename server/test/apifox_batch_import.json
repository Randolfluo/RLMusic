                            {
                                "key": "Content-Type",
                                "value": "{{contentType}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ]
                        },
                        "description": "Internal ID: adminLogin",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"123456\"\n}",
                            "options": {
