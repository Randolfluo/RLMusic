    "item": [
        {
            "name": "auth",
            "item": [
                {
                    "name": "用户注册",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "{{contentType}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/register",
                            "host": [
                                "{{baseUrl}}"
                            ]
                        },
                        "description": "如果遇到 \"数据库操作异常 (9004)\" 或 \"User exist\"，说明用户已存在，请直接运行第 2 步 \"用户登录\"",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"username\": \"{{username}}\",\n    \"password\": \"{{password}}\",\n    \"email\": \"{{email}}\"\n}",
                            "options": {
                                "raw": {
                                    "language": "text"
                                }
                            }
                        }
                    }
                },
                {
                    "name": "用户登录",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "{{contentType}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ]
                        },
                        "description": "Internal ID: login",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"username\": \"{{username}}\",\n    \"password\": \"{{password}}\"\n}",
                            "options": {
                                "raw": {
                                    "language": "text"
                                }
                            }
                        }
                    }
                },
                {
                    "name": "管理员登录",
