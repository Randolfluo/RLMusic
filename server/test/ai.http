### 全局变量
@baseUrl = http://localhost:12345/api
@contentType = application/json

@contentType = application/json
@username = admin
@password = 123456

# 登录请求用于获取 Token
### 2. 用户登录
# @name login
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
    "username": "{{username}}",
    "password": "{{password}}"
}



### 1. 语音合成 (TTS)
# @name tts
POST {{baseUrl}}/ai/tts
Content-Type: {{contentType}}

{
    "text": "你好，这是一段测试语音，用于验证阿里百炼语音合成接口。",
    "voice": "Neil",
    "format": "flac",
    "sample_rate": 24000,
    "volume": 50,
    "rate": 1.0,
    "pitch": 1.0
}

### 2. 硅基流动 Qwen 对话
# @name chat
POST {{baseUrl}}/ai/chat
Content-Type: {{contentType}}
{
    "prompt": "写一个20字的周杰伦的歌曲青花瓷的推荐语，用空格表示情感"
}






# ### 获取歌单详情 (精简版，随机返回歌曲，上限100) (需要登录)
# GET {{baseUrl}}/song/playlist/detail/11
# Authorization: Bearer {{login.response.body.data.token}}

# ### 3. 获取歌单AI分析
# GET {{baseUrl}}/song/playlist/analysis/11
# Authorization: Bearer {{login.response.body.data.token}}

### 4. 生成歌单AI描述
GET {{baseUrl}}/song/playlist/description/11
Authorization: Bearer {{login.response.body.data.token}}

### 5. 批量生成所有公共歌单AI描述 (Admin only)
POST {{baseUrl}}/song/playlist/generate-public-descriptions
Authorization: Bearer {{login.response.body.data.token}}



# ### 6. 获取艺术家详情 (随机歌曲)
# GET {{baseUrl}}/song/artist/detail/1?limit=100
# Authorization: Bearer {{login.response.body.data.token}}

# ### 7. 获取艺术家AI分析 (Step 1: JSON) (仅管理员)
# GET {{baseUrl}}/song/artist/analysis/1
# Authorization: Bearer {{login.response.body.data.token}}

### 8. 生成艺术家AI描述 (Step 2: Text) (需要登录)
GET {{baseUrl}}/song/artist/description/1
Authorization: Bearer {{login.response.body.data.token}}

### 9. 批量生成所有艺术家AI描述 (需要登录)
POST {{baseUrl}}/song/artist/generate-descriptions
Authorization: Bearer {{login.response.body.data.token}}

# ### 10. 获取专辑详情 (随机歌曲)
# GET {{baseUrl}}/song/album/detail/1?limit=100
# Authorization: Bearer {{login.response.body.data.token}}

# ### 11. 获取专辑AI分析 (Step 1: JSON) (需要登录)
# GET {{baseUrl}}/song/album/analysis/1
# Authorization: Bearer {{login.response.body.data.token}}

### 12. 生成专辑AI描述 (Step 2: Text) (需要登录)
GET {{baseUrl}}/song/album/description/1
Authorization: Bearer {{login.response.body.data.token}}

### 13. 批量生成所有专辑AI描述 (需要登录)
POST {{baseUrl}}/song/album/generate-descriptions
Authorization: Bearer {{login.response.body.data.token}}




# ### 14. 获取歌曲AI分析 (Step 1: JSON)
# GET {{baseUrl}}/song/podcast/analysis/1
# Authorization: Bearer {{login.response.body.data.token}}

# ### 15. 获取歌曲AI开场白草稿 (Step 2: Text)
# GET {{baseUrl}}/song/podcast/draft/1
# Authorization: Bearer {{login.response.body.data.token}}

# ### 16. 获取歌曲AI最终开场白 (Step 3: Text)
# GET {{baseUrl}}/song/podcast/opening/1
# Authorization: Bearer {{login.response.body.data.token}}

### 17. 生成歌曲AI最终开场白并转语音 (Step 4: TTS)
GET {{baseUrl}}/song/podcast/opening-tts/1
Authorization: Bearer {{login.response.body.data.token}}

### 18. 批量生成歌单内歌曲的开场白
POST {{baseUrl}}/song/podcast/generate-playlist-intros/14
Authorization: Bearer {{login.response.body.data.token}}
Content-Type: {{contentType}}

{
    "voice": "Neil"
}

### 19. 获取歌曲开场白文本
GET {{baseUrl}}/song/opening/text/1
Authorization: Bearer {{login.response.body.data.token}}

### 20. 获取歌曲开场白语音 (Stream)
GET {{baseUrl}}/song/opening/1
Authorization: Bearer {{login.response.body.data.token}}





