{
	"info": {
		"_postman_id": "websocket-collection-id",
		"name": "LocalMusicPlayer WebSocket Messages",
		"description": "This collection contains the JSON payloads for the LocalMusicPlayer WebSocket API. Import this into Apifox/Postman to easily access the message structures.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "WebSocket Connection Info",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "ws://localhost:3000/api/ws/chat",
					"protocol": "ws",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"api",
						"ws",
						"chat"
					]
				},
				"description": "Connect to this URL to start the WebSocket session.\n\n**Supported Messages**:\n- HELLO\n- TIME_SYNC_REQ\n- HEARTBEAT\n- CHAT\n- JOIN_ROOM\n- LEAVE_ROOM\n- GET_ROOM_LIST"
			},
			"response": []
		},
		{
			"name": "1. HELLO (Init)",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"type\": \"HELLO\",\n    \"payload\": {\n        \"info\": \"client-init\"\n    }\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "ws://localhost:3000/api/ws/chat",
					"protocol": "ws",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"api",
						"ws",
						"chat"
					]
				},
				"description": "Send this immediately after connection to initialize."
			},
			"response": []
		},
		{
			"name": "2. JOIN_ROOM",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"type\": \"JOIN_ROOM\",\n    \"payload\": {\n        \"roomId\": \"room-1\",\n        \"user\": {\n            \"id\": \"user-123\",\n            \"name\": \"Alice\",\n            \"avatar\": \"http://example.com/avatar.png\"\n        }\n    }\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "ws://localhost:3000/api/ws/chat",
					"protocol": "ws",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"api",
						"ws",
						"chat"
					]
				},
				"description": "Join a specific room."
			},
			"response": []
		},
		{
			"name": "3. CHAT",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"type\": \"CHAT\",\n    \"payload\": {\n        \"targetRoomId\": \"room-1\",\n        \"content\": \"Hello everyone!\",\n        \"sender\": {\n            \"id\": \"user-123\",\n            \"name\": \"Alice\"\n        }\n    }\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "ws://localhost:3000/api/ws/chat",
					"protocol": "ws",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"api",
						"ws",
						"chat"
					]
				},
				"description": "Send a chat message to a room."
			},
			"response": []
		},
		{
			"name": "4. LEAVE_ROOM",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"type\": \"LEAVE_ROOM\",\n    \"payload\": {\n        \"roomId\": \"room-1\",\n        \"user\": {\n            \"id\": \"user-123\"\n        }\n    }\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "ws://localhost:3000/api/ws/chat",
					"protocol": "ws",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"api",
						"ws",
						"chat"
					]
				},
				"description": "Leave a room."
			},
			"response": []
		},
		{
			"name": "5. HEARTBEAT",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"type\": \"HEARTBEAT\",\n    \"payload\": {\n        \"timestamp\": 1678900000000\n    }\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "ws://localhost:3000/api/ws/chat",
					"protocol": "ws",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"api",
						"ws",
						"chat"
					]
				},
				"description": "Send heartbeat to keep connection alive and measure RTT."
			},
			"response": []
		},
		{
			"name": "6. TIME_SYNC_REQ",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"type\": \"TIME_SYNC_REQ\",\n    \"payload\": {\n        \"client_now\": 1678900000000\n    }\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "ws://localhost:3000/api/ws/chat",
					"protocol": "ws",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"api",
						"ws",
						"chat"
					]
				},
				"description": "Request server time for synchronization."
			},
			"response": []
		},
		{
			"name": "7. GET_ROOM_LIST",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"type\": \"GET_ROOM_LIST\",\n    \"payload\": {}\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "ws://localhost:3000/api/ws/chat",
					"protocol": "ws",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"api",
						"ws",
						"chat"
					]
				},
				"description": "Get list of active rooms."
			},
			"response": []
		}
