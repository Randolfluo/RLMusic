### 全局变量
@baseUrl = http://localhost:12345/api
@contentType = application/json
@username = admin
@password = 123456
@email = test001@example.com

# 登录请求用于获取 Token
### 2. 用户登录
# @name login
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
    "username": "{{username}}",
    "password": "{{password}}"
}




### 11-2a. 获取公共歌单详情 (无需登录，验证 is_public)
GET {{baseUrl}}/song/playlist/public/11?page=1&limit=90

### 11-2c. 获取歌单详情 (精简版，随机返回歌曲，上限100) (需要登录)
GET {{baseUrl}}/song/playlist/detail/11
Authorization: Bearer {{login.response.body.data.token}}

### 11-2b. 获取私有歌单详情 (需要登录，验证 owner_id)
GET {{baseUrl}}/song/playlist/private/1?page=1&limit=90
Authorization: Bearer {{login.response.body.data.token}}

### 14. 获取所有公开歌单 (无需登录)
GET {{baseUrl}}/song/playlists/public
# 返回 is_public=true 的歌单，包含 total_songs 字段


### 14-3. 获取我的私有歌单 (需要登录)
GET {{baseUrl}}/song/playlists/user/private
Authorization: Bearer {{login.response.body.data.token}}
# 返回 owner_id 为当前用户，且 is_public=false 的歌单，包含 total_songs 字段

### 15. 更新歌单信息(包括权限) (需要登录)
PUT {{baseUrl}}/song/playlist/1
Authorization: Bearer {{login.response.body.data.token}}
Content-Type: {{contentType}}

{
    "title": "已修改的歌单名称",
    "description": "这是新的描述",
    "is_public": false
}



### 11-1. 创建私有歌单 (需要登录)
POST {{baseUrl}}/song/playlist
Authorization: Bearer {{login.response.body.data.token}}
Content-Type: {{contentType}}

{
    "title": "我的私有歌单",
    "description": "这是一个测试创建的私有歌单"
}
# {
#   "code": 1000,
#   "message": "success",
#   "data": {
#     "id": 21,
#     "title": "我的私有歌单",
#     "description": "这是一个测试创建的私有歌单",
#     "is_public": false,
#     "cover_url": "",
#     "owner_id": 2,
#     "songs": null,
#     "play_count": 0
#   }
# }



### 16. 批量添加歌曲到歌单
POST {{baseUrl}}/song/playlist/add-songs
Authorization: Bearer {{login.response.body.data.token}}
Content-Type: {{contentType}}

{
    "playlist_id": 1,
    "song_ids": [1, 2]
}

### 17. 点赞/取消点赞歌曲 (需要登录)
POST {{baseUrl}}/song/like/1
Authorization: Bearer {{login.response.body.data.token}}
# {
#   "code": 1000,
#   "message": "success",
#   "data": {
#     "count": 2,
#     "message": "添加成功"
#   }
# }

### 18. 批量移除歌单中的歌曲
POST {{baseUrl}}/song/playlist/remove-songs
Authorization: Bearer {{login.response.body.data.token}}
Content-Type: {{contentType}}
{
    "playlist_id": 1,
    "song_ids": [1]
}




###  删除私有歌单
DELETE {{baseUrl}}/song/playlist/21
Authorization: Bearer {{login.response.body.data.token}}


### 删除公共歌单 (仅限管理员)
DELETE {{baseUrl}}/song/playlist/public/11
Authorization: Bearer {{login.response.body.data.token}}
