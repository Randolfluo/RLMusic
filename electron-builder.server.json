{
  "appId": "com.randolfluo.rlmusic.server",
  "productName": "RLMusic-Server",
  "directories": {
    "output": "release/server/${version}"
  },
  "files": [
    "dist",
    "dist-electron"
  ],
  "extraResources": [
    {
      "from": "resources/server.exe",
      "to": "server.exe"
    },
    {
      "from": "server/config.yml",
      "to": "config.yml"
    }
  ],
  "win": {
    "icon": "public/images/logo/favicon.png",
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "artifactName": "${productName}-Windows-${version}-Setup.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  },
  "mac": {
    "target": "dmg",
    "artifactName": "${productName}-Mac-${version}-Installer.${ext}"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "artifactName": "${productName}-Linux-${version}.${ext}"
  },
  "portable": {
    "artifactName": "${productName}-Windows-Portable-${version}.${ext}"
  }
}
