<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- 标题 -->
    <mxCell id="title" value="RLMusic 系统 B/S 架构图" style="text;html=1;strokeColor=none;fillColor=none;fontSize=18;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="300" y="30" width="300" height="30" as="geometry"/>
    </mxCell>

    <!-- ========== 表示层 (浏览器客户端) ========== -->
    <mxCell id="layer-client-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;arcSize=5;container=1;collapsible=0;movable=0;resizable=0" vertex="1" parent="1">
      <mxGeometry x="50" y="80" width="750" height="120" as="geometry"/>
    </mxCell>
    <mxCell id="layer-client-label" value="表示层 (客户端浏览器)" style="text;html=1;strokeColor=none;fillColor=none;fontSize=12;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="60" y="90" width="150" height="20" as="geometry"/>
    </mxCell>

    <!-- Web 浏览器 -->
    <mxCell id="client-browser" value="Web 浏览器&#xa;(Chrome/Firefox/Edge)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11" vertex="1" parent="1">
      <mxGeometry x="100" y="115" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- Vue3 前端应用 -->
    <mxCell id="client-vue" value="Vue3 前端应用&#xa;(TypeScript + Vite)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11" vertex="1" parent="1">
      <mxGeometry x="280" y="115" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- Wails 桌面端 -->
    <mxCell id="client-wails" value="Wails 桌面客户端&#xa;(Go + Webview)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize:11" vertex="1" parent="1">
      <mxGeometry x="460" y="115" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- 移动端适配 -->
    <mxCell id="client-mobile" value="移动端适配&#xa;(响应式布局)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize:11" vertex="1" parent="1">
      <mxGeometry x="640" y="115" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- ========== 业务逻辑层 (后端服务) ========== -->
    <mxCell id="layer-server-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;arcSize=5;container=1;collapsible=0;movable=0;resizable=0" vertex="1" parent="1">
      <mxGeometry x="50" y="230" width="750" height="200" as="geometry"/>
    </mxCell>
    <mxCell id="layer-server-label" value="业务逻辑层 (后端服务层)" style="text;html=1;strokeColor=none;fillColor=none;fontSize=12;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="60" y="240" width="150" height="20" as="geometry"/>
    </mxCell>

    <!-- Web 服务器 (Nginx) -->
    <mxCell id="server-nginx" value="Web 服务器&#xa;(Nginx)&#xa;静态资源/反向代理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize:11" vertex="1" parent="1">
      <mxGeometry x="100" y="270" width="110" height="70" as="geometry"/>
    </mxCell>

    <!-- API 网关 -->
    <mxCell id="server-gateway" value="API 网关&#xa;(路由/认证/限流)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize:11" vertex="1" parent="1">
      <mxGeometry x="250" y="270" width="110" height="70" as="geometry"/>
    </mxCell>

    <!-- Gin 框架 -->
    <mxCell id="server-gin" value="Web 框架&#xa;(Go/Gin)&#xa;RESTful API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize:11" vertex="1" parent="1">
      <mxGeometry x="400" y="270" width="110" height="70" as="geometry"/>
    </mxCell>

    <!-- 业务模块 -->
    <mxCell id="server-modules" value="业务模块&#xa;├── 用户管理&#xa;├── 歌曲管理&#xa;├── 歌单管理&#xa;├── 播放服务&#xa;└── AI 服务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;spacingLeft=8" vertex="1" parent="1">
      <mxGeometry x="550" y="270" width="120" height="100" as="geometry"/>
    </mxCell>

    <!-- WebSocket 服务 -->
    <mxCell id="server-websocket" value="WebSocket 服务&#xa;(实时推送)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize:11" vertex="1" parent="1">
      <mxGeometry x="100" y="360" width="110" height="50" as="geometry"/>
    </mxCell>

    <!-- 中间件 -->
    <mxCell id="server-middleware" value="中间件&#xa;(JWT/日志/跨域)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize:11" vertex="1" parent="1">
      <mxGeometry x="250" y="360" width="110" height="50" as="geometry"/>
    </mxCell>

    <!-- 任务调度 -->
    <mxCell id="server-scheduler" value="定时任务&#xa;(音乐扫描/清理)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize:11" vertex="1" parent="1">
      <mxGeometry x="400" y="360" width="110" height="50" as="geometry"/>
    </mxCell>

    <!-- ========== 数据层 ========== -->
    <mxCell id="layer-data-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;arcSize=5;container=1;collapsible=0;movable=0;resizable=0" vertex="1" parent="1">
      <mxGeometry x="50" y="460" width="750" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="layer-data-label" value="数据层 (数据存储与缓存)" style="text;html=1;strokeColor=none;fillColor=none;fontSize=12;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="60" y="470" width="150" height="20" as="geometry"/>
    </mxCell>

    <!-- 关系型数据库 -->
    <mxCell id="data-mysql" value="关系型数据库&#xa;(MySQL/SQLite)&#xa;用户/歌曲/歌单数据" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=8;fillColor=#ffffff;strokeColor=#000000;fontSize=11" vertex="1" parent="1">
      <mxGeometry x="120" y="500" width="130" height="70" as="geometry"/>
    </mxCell>

    <!-- 本地文件存储 -->
    <mxCell id="data-files" value="本地文件系统&#xa;(音乐文件/封面/歌词)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11" vertex="1" parent="1">
      <mxGeometry x="320" y="505" width="130" height="60" as="geometry"/>
    </mxCell>

    <!-- 音频处理 -->
    <mxCell id="data-audio" value="音频处理&#xa;(FFmpeg/元数据提取)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11" vertex="1" parent="1">
      <mxGeometry x="520" y="505" width="130" height="60" as="geometry"/>
    </mxCell>

    <!-- 缓存 -->
    <mxCell id="data-cache" value="内存缓存&#xa;(播放列表/热数据)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11" vertex="1" parent="1">
      <mxGeometry x="680" y="505" width="100" height="60" as="geometry"/>
    </mxCell>

    <!-- ========== 层间连接线 ========== -->

    <!-- 客户端到 Web 服务器 -->
    <mxCell id="conn-client-nginx" edge="1" parent="1" source="client-browser" target="server-nginx" style="strokeColor=#000000;endArrow=classic;endFill=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="label-http1" value="HTTP/HTTPS" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9" vertex="1" connectable="0" parent="conn-client-nginx">
      <mxGeometry x="-0.5" relative="1" as="geometry">
        <mxPoint x="25" as="offset"/>
      </mxGeometry>
    </mxCell>

    <!-- Vue3 到 API 网关 -->
    <mxCell id="conn-vue-gateway" edge="1" parent="1" source="client-vue" target="server-gateway" style="strokeColor=#000000;endArrow=classic;endFill=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="label-api" value="REST API / JSON" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9" vertex="1" connectable="0" parent="conn-vue-gateway">
      <mxGeometry x="-0.5" relative="1" as="geometry">
        <mxPoint x="30" as="offset"/>
      </mxGeometry>
    </mxCell>

    <!-- Wails 到 Gin -->
    <mxCell id="conn-wails-gin" edge="1" parent="1" source="client-wails" target="server-gin" style="strokeColor=#000000;endArrow=classic;endFill=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="label-bind" value="Go Binding" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9" vertex="1" connectable="0" parent="conn-wails-gin">
      <mxGeometry x="-0.5" relative="1" as="geometry">
        <mxPoint x="20" as="offset"/>
      </mxGeometry>
    </mxCell>

    <!-- API 网关到 Gin -->
    <mxCell id="conn-gateway-gin" edge="1" parent="1" source="server-gateway" target="server-gin" style="strokeColor=#000000;endArrow=classic;endFill=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Gin 到业务模块 -->
    <mxCell id="conn-gin-modules" edge="1" parent="1" source="server-gin" target="server-modules" style="strokeColor=#000000;endArrow=classic;endFill=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- 业务模块到数据库 -->
    <mxCell id="conn-modules-db" edge="1" parent="1" source="server-modules" target="data-mysql" style="strokeColor=#000000;endArrow=classic;endFill=1;">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="610" y="440"/>
          <mxPoint x="185" y="440"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="label-sql" value="SQL (GORM)" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9" vertex="1" connectable="0" parent="conn-modules-db">
      <mxGeometry x="-0.8" relative="1" as="geometry">
        <mxPoint x="10" as="offset"/>
      </mxGeometry>
    </mxCell>

    <!-- 业务模块到文件存储 -->
    <mxCell id="conn-modules-files" edge="1" parent="1" source="server-modules" target="data-files" style="strokeColor=#000000;endArrow=classic;endFill=1;">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="580" y="450"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="label-io" value="文件 I/O" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9" vertex="1" connectable="0" parent="conn-modules-files">
      <mxGeometry x="-0.5" relative="1" as="geometry">
        <mxPoint x="15" as="offset"/>
      </mxGeometry>
    </mxCell>

    <!-- 业务模块到音频处理 -->
    <mxCell id="conn-modules-audio" edge="1" parent="1" source="server-modules" target="data-audio" style="strokeColor=#000000;endArrow=classic;endFill=1;">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="640" y="450"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- WebSocket 双向连接 -->
    <mxCell id="conn-ws" edge="1" parent="1" source="server-websocket" target="client-vue" style="strokeColor=#000000;endArrow=classic;startArrow=classic;endFill=1;startFill=1;dashed=1;">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="155" y="250"/>
          <mxPoint x="340" y="250"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="label-ws" value="WebSocket" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9" vertex="1" connectable="0" parent="conn-ws">
      <mxGeometry x="-0.5" relative="1" as="geometry">
        <mxPoint as="offset"/>
      </mxGeometry>
    </mxCell>

  </root>
</mxGraphModel>
